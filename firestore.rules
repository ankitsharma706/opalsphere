rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: events
    // Fields: title, type, date, location, images, status, description, budget
    //
    // Collection: bookings
    // Fields: userId, eventType, date, location, budget, theme, status, createdAt
    //
    // Collection: products
    // Fields: name, price, category, image, description, stock
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ankitkumar999090@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'client', 'decorator'] &&
             data.email is string && data.email.size() < 255;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'eventType', 'status']) &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /events/{eventId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /products/{productId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }
  }
}
